# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL (looks like: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-url-here

# Your Supabase anon/public key (long string starting with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-key-here

# ============================================
# SITE CONFIGURATION
# ============================================
# Your site URL (use http://localhost:3000 for development)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Owner email (Anant's email - has GOD MODE access)
NEXT_PUBLIC_ADMIN_EMAIL=anantshukla836@gmail.com

# Admin secret route (keep this secret!)
ADMIN_SECRET_ROUTE=admin-phoenix-gate

# Admin secret for API routes (generate a random string)
ADMIN_SECRET=your_admin_secret_here

# Guest route secret (generate a random string)
GUEST_SECRET=your_guest_secret_here

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
# Get these from: https://cloudinary.com/console

# Your Cloudinary cloud name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here

# Your Cloudinary API credentials
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ============================================
# EMAIL CONFIGURATION (Week 9-10)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
ADMIN_EMAIL=anant@ietlucknow.ac.in
